{
  "name": "linux-vm",
  "type": "linux",
  "qemu_binary": "qemu-system-aarch64",
  "machine": "virt",
  "cpu_model": "cortex-a72",
  "accelerator": "kvm",
  "ram": "2048",
  "cpus": "2",
  "disk_size": "4G",
  "efi_firmware": "/usr/share/qemu-efi-aarch64/QEMU_EFI.fd",
  "extra_flags": [
    "-device", "virtio-gpu-pci",
    "-device", "usb-ehci",
    "-device", "usb-kbd",
    "-device", "usb-mouse"
  ]
}
